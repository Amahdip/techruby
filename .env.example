# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Inbox that receives contact form submissions
CONTACT_TO_EMAIL=you@example.com

# resend | formsubmit | resend-proxy
CONTACT_PROVIDER=resend-proxy

# URL of the Vercel contact proxy (see contact-proxy/)
# RESEND_PROXY_URL=https://your-project.vercel.app/api/contact

# Verified sender on your domain (required in production)
# CONTACT_FROM_EMAIL=TechRuby <contact@techruby.ir>
